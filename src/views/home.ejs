<%- include("partials/header") %>

<section class="hero">
  <h1>Schedule LinkedIn posts. Publish automatically.</h1>
  <p class="lede">
    Write your posts, pick a date, time and timezone, and we publish them to your
    LinkedIn profile the moment they're due — no manual posting required.
  </p>
  <div class="cta-row">
    <a class="btn primary" href="/auth/register">Get started</a>
    <a class="btn" href="/auth/login">Log in</a>
  </div>
</section>

<section class="features">
  <div class="card">
    <h3>Connect once</h3>
    <p>Securely link your LinkedIn account with OAuth. Tokens are encrypted at rest.</p>
  </div>
  <div class="card">
    <h3>Schedule anywhere</h3>
    <p>Choose any date, time and timezone. We handle the conversion and the publishing.</p>
  </div>
  <div class="card">
    <h3>Stay in control</h3>
    <p>Edit, cancel, or retry posts. Track upcoming, published, and failed posts at a glance.</p>
  </div>
</section>

