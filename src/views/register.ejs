<%- include("partials/header") %>

<section class="auth-card">
  <h1><%= t("auth.register") %></h1>
  <% if (error) { %><p class="alert error"><%= error %></p><% } %>
  <form action="/auth/register" method="post" class="stack">
    <label>
      <%= t("auth.name") %> <span class="muted">(<%= t("common.optional") %>)</span>
      <input type="text" name="name" autocomplete="name" />
    </label>
    <label>
      <%= t("auth.email") %>
      <input type="email" name="email" value="<%= email %>" required autocomplete="email" />
    </label>
    <label>
      <%= t("auth.password") %> <span class="muted">(<%= t("auth.password.min") %>)</span>
      <input type="password" name="password" required minlength="8" autocomplete="new-password" />
    </label>
    <button type="submit" class="btn primary"><%= t("auth.submit") %></button>
  </form>
  <p class="muted"><%= t("auth.already") %> <a href="/auth/login"><%= t("auth.login") %></a>.</p>
</section>

<%- include("partials/footer") %>
