<%- include("partials/header") %>

<section class="auth-card">
  <h1><%= t("auth.login") %></h1>
  <% if (error) { %><p class="alert error"><%= error %></p><% } %>
  <form action="/auth/login" method="post" class="stack">
    <label>
      <%= t("auth.email") %>
      <input type="email" name="email" value="<%= email %>" required autocomplete="email" />
    </label>
    <label>
      <%= t("auth.password") %>
      <input type="password" name="password" required autocomplete="current-password" />
    </label>
    <button type="submit" class="btn primary"><%= t("auth.login.submit") %></button>
  </form>
  <p class="muted"><%= t("auth.noaccount") %> <a href="/auth/register"><%= t("auth.register") %></a>.</p>
</section>

<%- include("partials/footer") %>
