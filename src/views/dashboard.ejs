<%- include("partials/header") %>

<h1><%= t("nav.dashboard") %></h1>

<% if (flash.connected) { %><p class="alert success"><%= t("dash.connected") %></p><% } %>
<% if (flash.disconnected) { %><p class="alert info"><%= t("linkedin.disconnect") %></p><% } %>
<% if (flash.linkedinError) { %><p class="alert error"><%= t("linkedin.error") %>: <%= flash.linkedinError %></p><% } %>

<section class="card linkedin-status">
  <h3><%= t("linkedin.connection") %></h3>
  <% if (linkedinAccount) { %>
    <p class="connected">
      <%= t("dash.connected") %><% if (linkedinAccount.linkedinDisplayName) { %> — <strong><%= linkedinAccount.linkedinDisplayName %></strong><% } %>.
    </p>
    <% if (!linkedinAccount.linkedinPersonUrn) { %>
      <p class="alert error"><%= t("dash.nourn") %></p>
    <% } %>
    <form action="/auth/linkedin/disconnect" method="post" class="inline">
      <button type="submit" class="btn danger"><%= t("linkedin.disconnect") %></button>
    </form>
  <% } else { %>
    <p><%= t("linkedin.needconnect") %></p>
    <a class="btn primary" href="/auth/linkedin"><%= t("linkedin.connect") %></a>
  <% } %>
</section>

<div class="grid-2">
  <section class="card">
    <h3><%= t("post.upcoming") %></h3>
    <% if (upcoming.length === 0) { %>
      <p class="muted"><%= t("dash.noupcoming") %> <a href="/posts/new"><%= t("dash.scheduleone") %> →</a></p>
    <% } else { %>
      <ul class="post-mini-list">
        <% upcoming.forEach((p) => { %>
          <li>
            <span class="badge badge-<%= p.status.toLowerCase() %>"><%= p.status %></span>
            <span class="when"><%= formatInZone(p.scheduledAt, p.timezone) %> (<%= p.timezone %>)</span>
            <span class="excerpt"><%= p.body.slice(0, 80) %><%= p.body.length > 80 ? "…" : "" %></span>
            <a href="/posts/<%= p.id %>/edit"><%= t("post.edit") %></a>
          </li>
        <% }) %>
      </ul>
    <% } %>
  </section>

  <section class="card">
    <h3><%= t("post.published") %></h3>
    <% if (recentlyPublished.length === 0) { %>
      <p class="muted"><%= t("dash.nopublished") %></p>
    <% } else { %>
      <ul class="post-mini-list">
        <% recentlyPublished.forEach((p) => { %>
          <li>
            <span class="badge badge-published">PUBLISHED</span>
            <span class="when"><%= formatInZone(p.publishedAt, p.timezone) %></span>
            <span class="excerpt"><%= p.body.slice(0, 80) %><%= p.body.length > 80 ? "…" : "" %></span>
          </li>
        <% }) %>
      </ul>
    <% } %>
  </section>
</div>

<section class="card">
  <h3><%= t("post.failed") %></h3>
  <% if (failed.length === 0) { %>
    <p class="muted"><%= t("dash.nofailed") %></p>
  <% } else { %>
    <ul class="post-mini-list">
      <% failed.forEach((p) => { %>
        <li class="failed-row">
          <span class="badge badge-failed">FAILED</span>
          <span class="excerpt"><%= p.body.slice(0, 80) %><%= p.body.length > 80 ? "…" : "" %></span>
          <span class="error-msg"><%= p.errorMessage %></span>
          <span class="row-actions">
            <form action="/posts/<%= p.id %>/retry" method="post" class="inline">
              <button type="submit" class="btn small"><%= t("post.retry") %></button>
            </form>
            <a href="/posts/<%= p.id %>/edit" class="btn small"><%= t("post.edit") %></a>
          </span>
        </li>
      <% }) %>
    </ul>
  <% } %>
</section>

<%- include("partials/footer") %>
