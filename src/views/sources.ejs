<%- include("partials/header") %>

<h1><%= t("sources.title") %></h1>
<p class="muted"><%= t("sources.intro") %> <a href="/queue"><%= t("queue.title") %></a>.</p>

<% if (!linkedinReady) { %>
  <p class="alert error"><%= t("linkedin.needconnect") %> <a href="/auth/linkedin"><%= t("linkedin.connect") %></a>.</p>
<% } %>

<section class="card">
  <h3><%= t("sources.upload") %></h3>
  <div class="upload-row">
    <input type="file" id="source-input" accept="application/pdf" />
    <button type="button" id="source-upload-btn" class="btn"><%= t("sources.uploadbtn") %></button>
    <span id="source-status" class="muted" role="status" aria-live="polite"></span>
  </div>

  <h3 style="margin-top:1.25rem"><%= t("sources.fromurl") %></h3>
  <div class="upload-row">
    <input type="url" id="source-url" placeholder="<%= t("sources.urlph") %>" />
    <button type="button" id="source-url-btn" class="btn"><%= t("sources.add") %></button>
    <span id="source-url-status" class="muted" role="status" aria-live="polite"></span>
  </div>

  <h3 style="margin-top:1.25rem"><%= t("sources.fromnews") %></h3>
  <div class="upload-row">
    <input type="text" id="source-news" placeholder="<%= t("sources.newsph") %>" />
    <button type="button" id="source-news-btn" class="btn"><%= t("sources.search") %></button>
    <span id="source-news-status" class="muted" role="status" aria-live="polite"></span>
  </div>
</section>

<section class="card">
  <h3><%= t("sources.your") %></h3>
  <% if (!sources.length) { %>
    <p class="empty" id="no-sources"><%= t("sources.none") %></p>
  <% } %>
  <ul id="source-list" class="post-mini-list">
    <% sources.forEach((s) => { %>
      <li class="source-item" data-source-id="<%= s.id %>">
        <strong><%= s.name %></strong>
        <span class="muted">· <%= s.charCount %> <%= t("sources.chars") %></span>
        <span class="row-actions">
          <button type="button" class="btn small generate-from" data-source-id="<%= s.id %>"><%= t("sources.editdrafts") %></button>
          <button type="button" class="btn small ghost delete-source" data-source-id="<%= s.id %>"><%= t("common.delete") %></button>
        </span>
        <% const urls = Array.isArray(s.sourceUrls) ? s.sourceUrls : []; %>
        <% if (urls.length) { %>
          <div class="source-refs">
            <span class="muted"><%= t("sources.verify") %></span>
            <ul>
              <% urls.forEach((r) => { let host = r.url; try { host = new URL(r.url).hostname.replace(/^www\./, ""); } catch (e) {} %>
                <li><a href="<%= r.url %>" target="_blank" rel="noopener noreferrer" title="<%= r.title || r.url %>"><%= r.title || r.url %></a> <span class="muted">(<%= host %>)</span></li>
              <% }) %>
            </ul>
          </div>
        <% } %>
      </li>
    <% }) %>
  </ul>

  <div class="generate-panel card" id="generate-panel" hidden>
    <h3><%= t("sources.generate") %></h3>
    <div class="ai-controls">
      <label>
        <%= t("ai.tone") %>
        <select id="gen-tone">
          <% if (savedTones && savedTones.length) { %>
            <optgroup label="Your saved voices">
              <% savedTones.forEach((p) => { %>
                <option value="saved:<%= p.id %>" data-instruction="<%= p.instruction.replace(/"/g, '&quot;') %>"><%= p.name %></option>
              <% }) %>
            </optgroup>
          <% } %>
          <optgroup label="Built-in tones">
            <% Object.entries(tonePresets).forEach(([key, tp]) => { %>
              <option value="<%= key %>"><%= tp.label %></option>
            <% }) %>
          </optgroup>
        </select>
      </label>
      <label>
        <%= t("post.language") %>
        <select id="gen-language">
          <% postLanguages.forEach((l) => { %>
            <option value="<%= l.code %>"><%= l.label %></option>
          <% }) %>
        </select>
      </label>
      <label>
        <%= t("post.length") %>
        <select id="gen-length">
          <% postLengths.forEach((l) => { %>
            <option value="<%= l.key %>" <%= l.key === "medium" ? "selected" : "" %>><%= t("length." + l.key) %> (~<%= l.chars %>)</option>
          <% }) %>
          <option value="__custom__"><%= t("length.custom") %></option>
        </select>
        <input id="gen-length-custom" type="number" min="120" max="1300" placeholder="<%= t("length.customph") %>" hidden />
      </label>
      <label>
        <%= t("sources.stance") %>
        <select id="gen-stance">
          <option value=""><%= t("ai.audience.optional") %></option>
          <% Object.entries(stances).forEach(([key, s]) => { %>
            <option value="<%= key %>"><%= s.label %></option>
          <% }) %>
        </select>
      </label>
      <label>
        <%= t("sources.count") %>
        <input type="number" id="gen-count" min="1" max="7" value="3" />
      </label>
      <label>
        <%= t("ai.audience") %> <span class="muted">(<%= t("ai.audience.optional") %>)</span>
        <input type="text" id="gen-audience" placeholder="e.g. IT decision-makers" />
      </label>
    </div>
    <div class="ai-actions">
      <button type="button" id="gen-run" class="btn primary" <%= linkedinReady ? "" : "disabled" %>><%= t("sources.generate") %></button>
      <span id="gen-status" class="muted" role="status" aria-live="polite"></span>
    </div>
  </div>
</section>

<section class="card">
  <h3><%= t("watch.title") %> <span class="muted">(<%= t("watch.every") %>)</span></h3>
  <p class="muted"><%= t("watch.intro") %></p>
  <form action="/sources/watches" method="post" class="ai-controls" style="align-items:flex-end">
    <label style="flex:2 1 240px">
      <%= t("sources.fromnews") %>
      <input type="text" name="query" placeholder="<%= t("sources.newsph") %>" required />
    </label>
    <label>
      <%= t("ai.tone") %>
      <select name="tonePresetId">
        <option value="">—</option>
        <% (savedTones || []).forEach((p) => { %><option value="<%= p.id %>"><%= p.name %></option><% }) %>
      </select>
    </label>
    <label>
      <%= t("sources.stance") %>
      <select name="stance">
        <option value="">—</option>
        <% Object.entries(stances).forEach(([key, s]) => { %><option value="<%= key %>"><%= s.label %></option><% }) %>
      </select>
    </label>
    <label>
      <%= t("post.language") %>
      <select name="language">
        <% postLanguages.forEach((l) => { %><option value="<%= l.code %>"><%= l.label %></option><% }) %>
      </select>
    </label>
    <button type="submit" class="btn primary"><%= t("watch.add") %></button>
  </form>

  <% if (!watches || !watches.length) { %>
    <p class="empty"><%= t("watch.none") %></p>
  <% } else { %>
    <ul class="post-mini-list">
      <% watches.forEach((w) => { %>
        <li>
          <strong><%= w.query %></strong>
          <span class="muted"><% if (w.stance) { %><%= w.stance %> · <% } %><%= w.language %></span>
          <form action="/sources/watches/<%= w.id %>/delete" method="post" class="inline" style="margin-left:auto" onsubmit="return confirm('Delete this watch?');">
            <button type="submit" class="btn small ghost"><%= t("common.delete") %></button>
          </form>
        </li>
      <% }) %>
    </ul>
  <% } %>
</section>

<section class="card">
  <h3><%= t("sources.recenttitle") %></h3>
  <p class="muted"><%= t("sources.recentintro") %></p>
  <div id="recent-topics" class="topic-chips">
    <% (recentTopics || []).forEach((tp) => { %>
      <span class="topic-chip" data-topic-id="<%= tp.id %>">
        <button type="button" class="topic-search" data-query="<%= tp.query %>"><%= tp.query %></button>
        <button type="button" class="topic-remove" title="<%= t('common.delete') %>" aria-label="<%= t('common.delete') %>">×</button>
      </span>
    <% }) %>
  </div>
  <p class="empty" id="no-topics" <%= (recentTopics && recentTopics.length) ? "hidden" : "" %>><%= t("sources.recentnone") %></p>
</section>

<%- include("partials/footer") %>
