<%- include("partials/header") %>

<h1>Content sources</h1>
<p class="muted">Upload a PDF (a brief, one-pager, article…). We extract its text and use it as source material to draft posts — which land in your <a href="/queue">approval queue</a>.</p>

<% if (!linkedinReady) { %>
  <p class="alert error">Connect your LinkedIn account before generating posts. <a href="/auth/linkedin">Connect LinkedIn</a>.</p>
<% } %>

<section class="card">
  <h3>Upload a PDF</h3>
  <div class="upload-row">
    <input type="file" id="source-input" accept="application/pdf" />
    <button type="button" id="source-upload-btn" class="btn">Upload &amp; parse</button>
    <span id="source-status" class="muted" role="status" aria-live="polite"></span>
  </div>
</section>

<section class="card">
  <h3>Your sources</h3>
  <% if (!sources.length) { %>
    <p class="muted" id="no-sources">No sources yet — upload a PDF above.</p>
  <% } %>
  <ul id="source-list" class="post-mini-list">
    <% sources.forEach((s) => { %>
      <li class="source-item" data-source-id="<%= s.id %>">
        <strong><%= s.name %></strong>
        <span class="muted">· <%= s.charCount %> chars</span>
        <span class="row-actions">
          <button type="button" class="btn small generate-from" data-source-id="<%= s.id %>">Generate drafts</button>
          <button type="button" class="btn small ghost delete-source" data-source-id="<%= s.id %>">Delete</button>
        </span>
      </li>
    <% }) %>
  </ul>

  <div class="generate-panel card" id="generate-panel" hidden>
    <h3>Generate drafts</h3>
    <div class="ai-controls">
      <label>
        Tone of voice
        <select id="gen-tone">
          <% if (savedTones && savedTones.length) { %>
            <optgroup label="Your saved voices">
              <% savedTones.forEach((p) => { %>
                <option value="saved:<%= p.id %>" data-instruction="<%= p.instruction.replace(/"/g, '&quot;') %>"><%= p.name %></option>
              <% }) %>
            </optgroup>
          <% } %>
          <optgroup label="Built-in tones">
            <% Object.entries(tonePresets).forEach(([key, tp]) => { %>
              <option value="<%= key %>"><%= tp.label %></option>
            <% }) %>
          </optgroup>
        </select>
      </label>
      <label>
        Post language
        <select id="gen-language">
          <% postLanguages.forEach((l) => { %>
            <option value="<%= l.code %>"><%= l.label %></option>
          <% }) %>
        </select>
      </label>
      <label>
        How many drafts?
        <input type="number" id="gen-count" min="1" max="7" value="3" />
      </label>
      <label>
        Audience <span class="muted">(optional)</span>
        <input type="text" id="gen-audience" placeholder="e.g. IT decision-makers" />
      </label>
    </div>
    <div class="ai-actions">
      <button type="button" id="gen-run" class="btn primary" <%= linkedinReady ? "" : "disabled" %>>Generate drafts</button>
      <span id="gen-status" class="muted" role="status" aria-live="polite"></span>
    </div>
  </div>
</section>

<%- include("partials/footer") %>
