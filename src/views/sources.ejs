<%- include("partials/header") %>

<h1><%= t("sources.title") %></h1>
<p class="muted"><%= t("sources.intro") %> <a href="/queue"><%= t("queue.title") %></a>.</p>

<% if (!linkedinReady) { %>
  <p class="alert error"><%= t("linkedin.needconnect") %> <a href="/auth/linkedin"><%= t("linkedin.connect") %></a>.</p>
<% } %>

<section class="card">
  <h3><%= t("sources.upload") %></h3>
  <div class="upload-row">
    <input type="file" id="source-input" accept="application/pdf" />
    <button type="button" id="source-upload-btn" class="btn"><%= t("sources.uploadbtn") %></button>
    <span id="source-status" class="muted" role="status" aria-live="polite"></span>
  </div>
</section>

<section class="card">
  <h3><%= t("sources.your") %></h3>
  <% if (!sources.length) { %>
    <p class="muted" id="no-sources"><%= t("sources.none") %></p>
  <% } %>
  <ul id="source-list" class="post-mini-list">
    <% sources.forEach((s) => { %>
      <li class="source-item" data-source-id="<%= s.id %>">
        <strong><%= s.name %></strong>
        <span class="muted">· <%= s.charCount %> <%= t("sources.chars") %></span>
        <span class="row-actions">
          <button type="button" class="btn small generate-from" data-source-id="<%= s.id %>"><%= t("sources.generate") %></button>
          <button type="button" class="btn small ghost delete-source" data-source-id="<%= s.id %>"><%= t("common.delete") %></button>
        </span>
      </li>
    <% }) %>
  </ul>

  <div class="generate-panel card" id="generate-panel" hidden>
    <h3><%= t("sources.generate") %></h3>
    <div class="ai-controls">
      <label>
        <%= t("ai.tone") %>
        <select id="gen-tone">
          <% if (savedTones && savedTones.length) { %>
            <optgroup label="Your saved voices">
              <% savedTones.forEach((p) => { %>
                <option value="saved:<%= p.id %>" data-instruction="<%= p.instruction.replace(/"/g, '&quot;') %>"><%= p.name %></option>
              <% }) %>
            </optgroup>
          <% } %>
          <optgroup label="Built-in tones">
            <% Object.entries(tonePresets).forEach(([key, tp]) => { %>
              <option value="<%= key %>"><%= tp.label %></option>
            <% }) %>
          </optgroup>
        </select>
      </label>
      <label>
        <%= t("post.language") %>
        <select id="gen-language">
          <% postLanguages.forEach((l) => { %>
            <option value="<%= l.code %>"><%= l.label %></option>
          <% }) %>
        </select>
      </label>
      <label>
        <%= t("sources.count") %>
        <input type="number" id="gen-count" min="1" max="7" value="3" />
      </label>
      <label>
        <%= t("ai.audience") %> <span class="muted">(<%= t("ai.audience.optional") %>)</span>
        <input type="text" id="gen-audience" placeholder="e.g. IT decision-makers" />
      </label>
    </div>
    <div class="ai-actions">
      <button type="button" id="gen-run" class="btn primary" <%= linkedinReady ? "" : "disabled" %>><%= t("sources.generate") %></button>
      <span id="gen-status" class="muted" role="status" aria-live="polite"></span>
    </div>
  </div>
</section>

<%- include("partials/footer") %>
