<% if (aiEnabled) { %>
  <% const saved = (typeof savedTones !== "undefined" && savedTones) ? savedTones : []; %>
  <div class="ai-panel">
    <h3><%= t("ai.generate") %></h3>
    <label>
      <%= t("ai.topic") %>
      <textarea id="ai-topic" rows="2" placeholder="<%= t("ai.placeholder") %>"></textarea>
    </label>
    <div class="ai-controls">
      <label>
        <%= t("ai.tone") %>
        <select id="ai-tone">
          <% if (saved.length) { %>
            <optgroup label="Saved voices">
              <% saved.forEach((p) => { %>
                <option value="saved:<%= p.id %>" data-instruction="<%= p.instruction.replace(/"/g, '&quot;') %>"><%= p.name %></option>
              <% }) %>
            </optgroup>
          <% } %>
          <optgroup label="Built-in">
            <% Object.entries(tonePresets).forEach(([key, tp]) => { %>
              <option value="<%= key %>"><%= tp.label %></option>
            <% }) %>
            <option value="__custom__"><%= t("tone.custom") %></option>
          </optgroup>
        </select>
      </label>
      <label>
        <%= t("ai.audience") %> <span class="muted">(<%= t("ai.audience.optional") %>)</span>
        <input id="ai-audience" type="text" placeholder="<%= t("ai.audience.placeholder") %>" />
      </label>
      <label>
        <%= t("post.length") %>
        <select id="ai-length">
          <% postLengths.forEach((l) => { %>
            <option value="<%= l.key %>" <%= l.key === "medium" ? "selected" : "" %>><%= t("length." + l.key) %> (~<%= l.chars %>)</option>
          <% }) %>
          <option value="__custom__"><%= t("length.custom") %></option>
        </select>
        <input id="ai-length-custom" type="number" min="120" max="<%= maxLength %>" placeholder="<%= t("length.customph") %>" hidden />
      </label>
    </div>
    <label id="ai-custom-wrap" hidden>
      <%= t("ai.custom") %>
      <input id="ai-custom-tone" type="text" placeholder="<%= t("ai.custom.placeholder") %>" />
    </label>
    <div class="ai-actions">
      <button type="button" id="ai-generate" class="btn primary"><%= t("ai.button") %></button>
      <span id="ai-status" class="muted" role="status" aria-live="polite"></span>
    </div>

    <details class="learn-tone">
      <summary><%= t("ai.learn") %></summary>
      <p class="muted"><%= t("ai.learnhelp") %></p>
      <label>
        <%= t("ai.examples") %>
        <textarea id="learn-samples" rows="6" placeholder="<%= t("ai.examplesph") %>"></textarea>
      </label>
      <div class="ai-actions">
        <button type="button" id="learn-analyze" class="btn"><%= t("ai.analyze") %></button>
        <span id="learn-status" class="muted" role="status" aria-live="polite"></span>
      </div>
      <div id="learn-result" hidden>
        <label>
          <%= t("ai.captured") %> <span class="muted">(<%= t("ai.capturededit") %>)</span>
          <textarea id="learn-instruction" rows="6"></textarea>
        </label>
        <div class="learn-save-row">
          <input id="learn-name" type="text" placeholder="<%= t("ai.namevoice") %>" />
          <button type="button" id="learn-save" class="btn primary"><%= t("ai.savepreset") %></button>
        </div>
      </div>
    </details>
  </div>
<% } %>
