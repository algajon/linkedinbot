<%- include("partials/header") %>

<h1><%= t("routines.title") %></h1>
<p class="muted"><%= t("routines.intro") %> <a href="/queue"><%= t("queue.title") %></a><%= t("routines.introsuffix") %></p>

<% if (typeof errors !== "undefined" && errors && errors.length) { %>
  <ul class="alert error"><% errors.forEach((e) => { %><li><%= e %></li><% }) %></ul>
<% } %>

<section class="card">
  <h3><%= t("routines.create") %></h3>
  <form action="/routines" method="post" class="stack" id="routine-form">
    <label><%= t("routines.name") %><input type="text" name="name" placeholder="e.g. Weekday mornings" required /></label>

    <fieldset class="cadence-set">
      <legend><%= t("routines.cadence") %></legend>
      <label class="radio"><input type="radio" name="cadence" value="EVERY_24H" checked /> <%= t("routines.every24") %></label>
      <label class="radio"><input type="radio" name="cadence" value="EVERY_12H" /> <%= t("routines.every12") %></label>
      <label class="radio"><input type="radio" name="cadence" value="WEEKLY" /> <%= t("routines.weekly") %></label>
    </fieldset>

    <label>
      <%= t("post.timezone") %>
      <select name="timezone" required>
        <% timezones.forEach((tz) => { %>
          <option value="<%= tz %>" <%= tz === "UTC" ? "selected" : "" %>><%= tz %></option>
        <% }) %>
      </select>
    </label>

    <div id="anchor-block">
      <label><%= t("routines.start") %><input type="time" name="anchorTime" value="09:00" /></label>
    </div>

    <div id="weekly-block" hidden>
      <p class="muted"><%= t("routines.weeklyhint") %></p>
      <% for (let i = 0; i < 5; i++) { %>
        <div class="schedule-row weekly-row">
          <label>
            <%= t("routines.day") %>
            <select name="weekday">
              <% weekdays.forEach((d, idx) => { %>
                <option value="<%= idx %>" <%= idx === 1 ? "selected" : "" %>><%= d %></option>
              <% }) %>
            </select>
          </label>
          <label><%= t("post.time") %><input type="time" name="slotTime" /></label>
        </div>
      <% } %>
    </div>

    <button type="submit" class="btn primary"><%= t("routines.save") %></button>
  </form>
</section>

<section class="card">
  <h3><%= t("routines.your") %></h3>
  <% if (!routines.length) { %>
    <p class="empty"><%= t("routines.none") %></p>
  <% } else { %>
    <ul class="post-mini-list">
      <% routines.forEach((r) => { %>
        <li>
          <strong><%= r.name %></strong>
          <span class="badge badge-scheduled"><%= r.cadence %></span>
          <span class="muted"><%= r.timezone %><% if (r.cadence !== "WEEKLY") { %> · <%= t("routines.from") %> <%= r.anchorTime %><% } else if (r.slots) { %> · <%= (Array.isArray(r.slots) ? r.slots.length : 0) %> <%= t("routines.slotsweek") %><% } %></span>
          <form action="/routines/<%= r.id %>/delete" method="post" class="inline" onsubmit="return confirm('<%= t("confirm.delroutine") %>');">
            <button type="submit" class="btn small ghost"><%= t("common.delete") %></button>
          </form>
        </li>
      <% }) %>
    </ul>
  <% } %>
</section>

<%- include("partials/footer") %>
