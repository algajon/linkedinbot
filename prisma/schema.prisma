generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String?
  passwordHash String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  linkedinAccount LinkedInAccount?
  scheduledPosts  ScheduledPost[]
  tonePresets     TonePreset[]
  contentSources  ContentSource[]
  postingRoutines PostingRoutine[]
  newsWatches     NewsWatch[]
}

// A standing topic to monitor; the hourly job drafts a take on fresh articles.
model NewsWatch {
  id           String    @id @default(uuid())
  userId       String
  query        String
  tonePresetId String?
  stance       String?
  language     String    @default("en")
  active       Boolean   @default(true)
  seenUrls     Json?
  lastRunAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// A reusable, AI-distilled tone of voice learned from example posts.
model TonePreset {
  id          String   @id @default(uuid())
  userId      String
  name        String
  instruction String
  sampleText  String?
  openaiModel String?  // fine-tuned OpenAI model id (topic generation)
  dgxLora     String?  // vLLM LoRA adapter name (source generation)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// A document (PDF) whose extracted text feeds AI post generation.
model ContentSource {
  id            String   @id @default(uuid())
  userId        String
  name          String
  filename      String?
  kind          String   @default("pdf") // pdf | url | news
  extractedText String
  charCount     Int      @default(0)
  sourceUrls    Json?    // [{ title, url }] for url/news sources — for fact-checking
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// A cadence template that suggests publish times at approval.
model PostingRoutine {
  id         String   @id @default(uuid())
  userId     String
  name       String
  cadence    String   @default("EVERY_24H") // EVERY_12H | EVERY_24H | WEEKLY
  timezone   String   @default("UTC")
  anchorTime String?  // "HH:mm" start for EVERY_12H / EVERY_24H
  slots      Json?    // WEEKLY: [{ weekday: 0-6, time: "HH:mm" }]
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model LinkedInAccount {
  id                     String    @id @default(uuid())
  userId                 String    @unique
  linkedinPersonUrn      String?
  linkedinDisplayName    String?
  accessTokenEncrypted   String
  refreshTokenEncrypted  String?
  tokenExpiresAt         DateTime?
  refreshExpiresAt       DateTime?
  scopes                 String[]
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ScheduledPost {
  id                String      @id @default(uuid())
  userId            String
  linkedinAccountId String?
  authorUrn         String
  targetType        TargetType  @default(PERSONAL_PROFILE)
  body              String
  mediaUrl          String?
  mediaType         MediaType?
  uploadedFiles     UploadedFile[]
  scheduledAt       DateTime?
  timezone          String
  language          String      @default("en")
  status            PostStatus  @default(SCHEDULED)
  origin            String      @default("MANUAL")
  approvedAt        DateTime?
  contentSourceId   String?
  linkedinPostUrn   String?
  errorMessage      String?
  lockedAt          DateTime?
  publishedAt       DateTime?
  retryCount        Int         @default(0)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status, scheduledAt])
  @@index([userId])
}

model UploadedFile {
  id              String   @id @default(uuid())
  scheduledPostId String
  url             String
  filename        String
  mimeType        String
  size            Int
  data            Bytes?
  createdAt       DateTime @default(now())

  scheduledPost ScheduledPost @relation(fields: [scheduledPostId], references: [id], onDelete: Cascade)

  @@index([scheduledPostId])
}

model PublishLog {
  id              String   @id @default(uuid())
  scheduledPostId String
  status          String
  message         String?
  payload         Json?
  response        Json?
  createdAt       DateTime @default(now())
}

enum PostStatus {
  DRAFT
  PENDING_APPROVAL
  SCHEDULED
  PUBLISHING
  PUBLISHED
  FAILED
  CANCELED
}

enum TargetType {
  PERSONAL_PROFILE
  COMPANY_PAGE
}

enum MediaType {
  IMAGE
  VIDEO
  DOCUMENT
}
