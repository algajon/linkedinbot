# LinkedIn OAuth credentials (from https://www.linkedin.com/developers/apps)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:3000/auth/linkedin/callback
LINKEDIN_SCOPES=openid profile email w_member_social
# LinkedIn versioned API header (YYYYMM). Keep configurable — do not hardcode.
LINKEDIN_API_VERSION=202605

# App
APP_BASE_URL=http://localhost:3000
PORT=3000
NODE_ENV=development

# In-process publisher: runs publish:due on a timer inside the web service.
# on/off/true/false/1/0. Default: on in production, off otherwise.
PUBLISH_SCHEDULER=off
# How often the in-process publisher runs (minutes).
PUBLISH_INTERVAL_MINUTES=60

# Database (Render Postgres connection string)
DATABASE_URL=postgresql://user:password@localhost:5432/linkedin_poster

# Public-content generation (posts, hashtags, ideas, tone briefs). If
# ANTHROPIC_API_KEY is set, Claude is used; otherwise it falls back to OpenAI.
# Confidential PDF generation still routes to the on-prem DGX cluster.
ANTHROPIC_API_KEY=
# Claude model. Defaults to claude-sonnet-4-6 (strong prose, lower cost/latency).
# For maximum quality set claude-opus-4-8 (higher cost).
ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenAI — used only when ANTHROPIC_API_KEY is unset.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Quality engine: best-of-N + LLM-judge + self-refine on every post.
# on (default) = higher quality, more tokens/latency; off = single-shot.
CONTENT_QUALITY=on

# On-prem DGX Spark (vLLM, OpenAI-compatible). When set, source-based generation
# runs through the internal cluster so document content never leaves the network.
# Only reachable from inside the office LAN/VPN — leave blank on cloud hosts.
DGX_BASE_URL=
DGX_API_KEY=
DGX_MODEL=Qwen/Qwen2.5-72B-Instruct
# Optional vLLM tier hint: fast (small model) | heavy (large model)
DGX_LLM_TIER=heavy

# Content sources: auto-delete uploaded sources older than this many days
# (extracted text is stored gzip-compressed). Set 0 to keep them forever.
SOURCE_RETENTION_DAYS=30

# Secrets
SESSION_SECRET=change-me-to-a-long-random-string
# 32-byte key, hex (64 chars) or base64. Generate: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=
# Shared secret for the cron/internal publish endpoint
CRON_SECRET=change-me
